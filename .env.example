DEBUG=True
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=127.0.0.1,localhost

# Ollama URL and models live in the database (System settings) after migrate.
# Optional one-time bootstrap: set these before the first `migrate` if you want
# them copied into the DB row; otherwise defaults are llava:latest / llama3:latest.
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_VISION_MODEL=llava:latest
# OLLAMA_TEXT_MODEL=llama3:latest
# Plain-text OCR model (optional; set on first migrate from env). e.g. glm-ocr:latest
# OLLAMA_OCR_MODEL=glm-ocr:latest
# USE_VISION_EXTRACTION=true
